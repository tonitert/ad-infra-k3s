# Copy this file to credentials.tfvars and replace the placeholders.
# credentials.tfvars is ignored by Git because it contains live secrets.

hcloud_token     = "<hetzner-cloud-read-write-token>"
cloudflare_token = "<cloudflare-api-token>"

# Optional: defaults to ./keys/ssh and ./keys/ssh.pub when left empty.
ssh_key_path = ""

# Optional: ArgoCD sync source repository.
repo_url = "https://github.com/tonitert/ad-infra-k3s"

# Optional: ArgoCD sync source revision.
repo_revision = "master"
